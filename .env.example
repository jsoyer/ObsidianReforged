# ObsidianReforged — environment variables example
# Copy this file to .env and fill in the values before running the monitoring stack.
#
# Usage:
#   cp .env.example .env
#   docker compose -f docker-compose.yml -f docker-compose.monitoring.yml up -d

# ── Required for monitoring overlay ──────────────────────────────────────────

# RCON password — must match rcon.password in server.properties
# Also requires enable-rcon=true in server.properties
RCON_PASSWORD=change-me

# Grafana admin password
GRAFANA_PASSWORD=change-me

# ── Optional server overrides ─────────────────────────────────────────────────

# Maximum JVM heap in MB (keep ~20% below the container memory limit)
# MaxMemory=2048

# Pin a specific Minecraft version
# Version=1.21.11

# Number of rolling backups to keep
# BackupCount=10

# Comma-separated folders to exclude from backups
# NoBackup=plugins,cache

# Disable ViaVersion (cross-version client support)
# NoViaVersion=Y

# Pin Geyser / Floodgate to a specific version
# GeyserVersion=2.4.0
# FloodgateVersion=2.2.3

# Suppress curl download progress in logs
# QuietCurl=Y
